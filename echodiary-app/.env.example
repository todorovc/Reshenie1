# EchoDiary — environment variables
# Copy to `.env` and fill in your own values. Never commit `.env`.

# --- Session ---------------------------------------------------------------
# A random secret used to sign the HTTP-only session cookie.
# Generate one with: openssl rand -base64 48
SESSION_SECRET=replace-me-with-a-long-random-value

# --- Spotify OAuth (PKCE) --------------------------------------------------
# Required to enable real Spotify sign-in. Without these the app runs in
# demo mode and the "Sign in with Spotify" button is replaced with the demo CTA.
#
# Create an app at https://developer.spotify.com/dashboard, copy the client ID,
# and register the exact redirect URI below in the app's settings.

# SPOTIFY_CLIENT_ID=your-spotify-client-id
# SPOTIFY_REDIRECT_URI=http://localhost:5000/auth/callback

# Optional. Spotify supports pure-PKCE without a client secret. If you prefer
# the confidential-client flow (still over PKCE), set the secret too.
# SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
